# .env.example — Template à copier pour chaque environnement
# Ce fichier EST commité. Les .env.* réels ne le sont PAS.
# Copier : cp .env.example .env.dev  (puis adapter les valeurs)

APP_ENV=dev
APP_DEBUG=true
LOG_LEVEL=DEBUG

DB_HOST=db
DB_PORT=3306
DB_NAME=videgrenierenligne
DB_USER=vgl_user
DB_PASSWORD=your_password_here
DB_ROOT_PASSWORD=your_root_password_here

SESSION_LIFETIME=3600
SESSION_SECURE=false

UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=/var/www/html/public/storage
